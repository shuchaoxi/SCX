\citation{bahadur1960deviations}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Two-layer t-SNE visualization of the AlN v3 dataset. (a) First-layer features (ACE descriptors) colored by coarse state assignment. (b) After error-driven encoding, the same samples are separated into eight substates with distinct error profiles. Red markers indicate the 53 frames identified as noisy by independent domain expert review. The concentration of noisy frames in the thermal and MLMD states is visually apparent.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:two_layer}{{2}{5}{Two-layer t-SNE visualization of the AlN v3 dataset. (a) First-layer features (ACE descriptors) colored by coarse state assignment. (b) After error-driven encoding, the same samples are separated into eight substates with distinct error profiles. Red markers indicate the 53 frames identified as noisy by independent domain expert review. The concentration of noisy frames in the thermal and MLMD states is visually apparent}{figure.2}{}}
